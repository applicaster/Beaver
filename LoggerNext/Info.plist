<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Sparkle keys. We keep this file alongside Xcode's auto-generated
      Info.plist (GENERATE_INFOPLIST_FILE = YES) because Xcode's
      INFOPLIST_KEY_* build settings silently drop third-party keys
      from the final plist. INFOPLIST_FILE points at this file and
      Xcode merges its contents on top of the generated keys.

      SUPublicEDKey is the Ed25519 public key generated locally via
      Sparkle's `generate_keys` tool. The matching private key lives
      in Anton's login Keychain (local dev signing) and CircleCI's
      SPARKLE_PRIVATE_KEY_BASE64 env var (CI signing). Don't change
      this string without also rotating both private-key locations
      and re-signing every published appcast entry — installed Beaver
      copies trust THIS key to validate update enclosures.

      SUFeedURL is also set programmatically via
      BeaverUpdaterDelegate.feedURLString(for:) — having it here too
      gives Sparkle a backstop if the delegate ever fails to attach.
    -->
    <key>SUFeedURL</key>
    <string>https://applicaster.github.io/Beaver/appcast.xml</string>

    <key>SUPublicEDKey</key>
    <string>ZYuSQ24/sz+w72KMK+mISy+FZvnv+QJGuiDs9DH4cs8=</string>
</dict>
</plist>
